[sub_resource type="GDScript" id="GDScript_qn10n"]
script/source = "@tool
extends Node3D

const TRAIL := preload(\"res://projectiles/scripts/trail3d.gd\")

@export var speed := 10.0
@export var fade_time := 0.3
@export_storage var lifetime := 5.0

var age := 0.0
var direction := Vector3(0, 0, 1)
var collided := false

var list := [
	[ \"Lifetime\", [
		{ \"property\": \"lifetime\" },
		{ \"node_path\": \"Emitters/Core\", \"property\": \"lifetime\" },
		{ \"node_path\": \"Emitters/Glow\", \"property\": \"lifetime\" },
	]],
	[ \"Main Color\", [
		{ \"node_path\": \"Emitters/Glow\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m1_rgb\" },
		{ \"node_path\": \"Impact/Glow\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m0_rgb\" },
		{ \"node_path\": \"Impact/GlowHard\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m0_rgb\" },
		{ \"node_path\": \"Impact/Flare\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m1_rgb\" },
		{ \"node_path\": \"Impact/Sparks\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
	]],
	[ \"Projectile Color\", [
		{ \"node_path\": \"Emitters/Core\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
	]],
	[ \"Trail Color\", [
		{ \"node_path\": \"TrailPrefab\", \"object_path\": \"material_override\", \"property\": \"shader_parameter/gradient\" }
	]],
	[ \"Smoke Color\", [
		{ \"node_path\": \"Impact/Smoke\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m6_rgb\" },
	]],
	[ \"Embers Color\", [
		{ \"node_path\": \"Impact/Embers\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m7_rgb\" },
	]],
]

func _ready() -> void:
	if !Engine.is_editor_hint():
		for e in $Emitters.get_children():
			e.restart()

func _process(delta: float) -> void:
	if Engine.is_editor_hint():
		return
	age += delta
	if collided:
		var s: float = $TrailPrefab.scale.y
		if s > 0.01:
			$TrailPrefab.scale.y = min(s, max(0.001, $TrailPrefab.scale.y - delta * (1.0 / maxf(fade_time, 0.01))))
	else:
		var ft := minf(lifetime, fade_time)
		var fade_progress: float = age - (lifetime - ft)
		if fade_progress > 0:
			var t := clampf(fade_progress / ft, 0.0, 1.0)
			var s := maxf(1.0 - t, 0.001)
			get_node(\"Emitters\").scale = Vector3(s, s, s)
			get_node(\"TrailPrefab\").scale = Vector3(s, s, s)
			for e in get_node(\"Emitters\").get_children():
				e.emitting = false
	if age > lifetime + 0.5:
		queue_free()

func _physics_process(delta: float) -> void:
	if Engine.is_editor_hint():
		return
	var motion := direction * delta * speed
	if collided:
		$Emitters.position += Vector3(0, 0, 1) * delta * speed
		return
	position += motion
	if age > lifetime:
		return
	var collision: KinematicCollision3D = $CharacterBody3D.move_and_collide(motion)
	if collision:
		explode()

func launch(dir: Vector3) -> void:
	dir = dir.normalized()
	direction = dir
	$CharacterBody3D.position = global_position
	var right := Vector3(0, 1, 0).cross(dir).normalized()
	var up := dir.cross(right).normalized()
	basis = Basis(
		right * scale.x,
		up * scale.y,
		dir * scale.z
	)

func explode() -> void:
	collided = true
	for e in $Emitters.get_children():
		e.emitting = false
		if e.one_shot:
			e.visible = false
	for e in $Impact.get_children():
		e.restart()

func _get_property_list() -> Array[Dictionary]:
	if !is_inside_tree() or !Engine.is_editor_hint():
		return []
	var l: Array[Dictionary]
	for group in list:
		for prop in group[1]:
			var node: Node = self
			if prop.has(\"node_path\"):
				node = get_node(prop.node_path)
				if !node:
					print(\"Node not found %s\" % prop.node_path)
					continue
			var obj: Object = node
			if prop.has(\"object_path\"):
				obj = node.get(prop.object_path)
				if !obj:
					print(\"Object not found %s\" % prop.object_path)
					continue
				if prop.has(\"sub_object_path\"):
					obj = obj.get(prop.sub_object_path)
					if !obj:
						print(\"Sub-object not found %s\" % prop.sub_object_path)
						continue
			if obj == self:
				continue
			var prop_list = obj.get_property_list()
			var done := false
			for p in prop_list:
				if p.name == prop.property:
					var property = p.duplicate()
					property.name = group[0]
					l.push_back(property)
					done = true
					break
			if done:
				break
	return l

func _get(property: StringName) -> Variant:
	if !is_inside_tree() or !Engine.is_editor_hint():
		return null
	var r := find_property(property)
	if !r.is_empty():
		return r.object.get(r.property)
	else:
		return null

func _set(property: StringName, value: Variant) -> bool:
	if !is_inside_tree() or !Engine.is_editor_hint():
		return false
	for group in list:
		if group[0] != property:
			continue
		for prop in group[1]:
			var node: Node = self
			if prop.has(\"node_path\"):
				node = get_node(prop.node_path)
				if !node:
					continue
			var obj: Object = node
			if prop.has(\"object_path\"):
				obj = node.get(prop.object_path)
				if !obj:
					continue
				if prop.has(\"sub_object_path\"):
					obj = obj.get(prop.sub_object_path)
					if !obj:
						continue
			obj.set(prop.property, value)
	return false

func find_property(property: StringName) -> Dictionary:
	for group in list:
		if property != group[0]:
			continue
		for prop in group[1]:
			var node: Node = self
			if prop.has(\"node_path\"):
				node = get_node(prop.node_path)
				if !node:
					continue
			var obj: Object = node
			if prop.has(\"object_path\"):
				obj = node.get(prop.object_path)
				if !obj:
					continue
				if prop.has(\"sub_object_path\"):
					obj = obj.get(prop.sub_object_path)
					if !obj:
						continue
			return { \"node\": node, \"object\": obj, \"property\": prop.property }
	return {}
"

[sub_resource type="Shader" id="Shader_5kh7j"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled;

uniform float emission = 1.0;

float rand(inout uint seed) {
	int k;
	int s = int(seed);
	if (s == 0) {
		s = 305420679;
	}
	k = s / 127773;
	s = 16807 * (s - k * 127773) - 2836 * k;
	if (s < 0) {
		s += 2147483647;
	}
	seed = uint(s);
	return float(seed % uint(65536)) / 65535.0;
}

float rand_range(inout uint seed, float l, float h) {
	return l + (h - l) * rand(seed);
}

varying flat uint instance_id;
varying float age;

void vertex()
{
	instance_id = uint(INSTANCE_ID);
	age = INSTANCE_CUSTOM.y;
}

void fragment()
{
	uint seed = instance_id;
	ALBEDO = COLOR.rgb * emission;
	
}


"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_lsi3j"]
render_priority = 1
shader = SubResource("Shader_5kh7j")
shader_parameter/emission = 4.0

[sub_resource type="Shader" id="Shader_4k8rb"]
code = "shader_type particles;
render_mode disable_velocity;

const float DEG_TO_RAD = PI / 180.0;
const uint AMOUNT = uint(1);

struct Particle {
	uint seed;
	float delta;
	float lifetime;
	uint index;
	uint number;
	float age;
	float normalized_age;
	float normalized_index;
	float normalized_number;
	vec3 initial_position;
	vec3 initial_scale;
	vec4 initial_color;
	vec3 initial_velocity;
	float radial_velocity;
	vec3 orbital_axis;
	float initial_orbital_speed;
	vec3 spawn_direction;
	vec3 position;
	vec3 scale;
	vec4 color;
	vec3 velocity;
	vec3 orbital_velocity;
	float orbital_speed;
	vec3 rotation_axis;
	float initial_rotation;
	float rotation;
	mat3 orientation;
	vec3 force;
	float animation_offset;
	float animation_speed;
	mat4 emission_transform;
	mat4 previous_transform;
	bool just_spawned;
	bool collided;
	vec3 collision_normal;
	float collision_depth;
};

float remap(float value, float input_min, float input_max, float output_min, float output_max) {
	float v = clamp(value, input_min, input_max);
	return (v - input_min) / (input_max - input_min) * (output_max - output_min) + output_min;
}

float rand(inout uint seed) {
	int k;
	int s = int(seed);
	if (s == 0) {
		s = 305420679;
	}
	k = s / 127773;
	s = 16807 * (s - k * 127773) - 2836 * k;
	if (s < 0) {
		s += 2147483647;
	}
	seed = uint(s);
	return float(seed % uint(65536)) / 65535.0;
}

float rand_range(inout uint seed, float l, float h) {
	return l + (h - l) * rand(seed);
}

uint hash(uint x) {
	x = ((x >> uint(16)) ^ x) * uint(73244475);
	x = ((x >> uint(16)) ^ x) * uint(73244475);
	x = (x >> uint(16)) ^ x;
	return x;
}

vec3 normalize_or_zero(vec3 v) {
  return length(v) > 0.0 ? normalize(v) : vec3(0.0, 0.0, 0.0);
}

vec3 normalize_or_up(vec3 v) {
  return length(v) > 0.0 ? normalize(v) : vec3(0.0, 1.0, 0.0);
}

vec4 quat(vec3 axis, float angle) {
  float s = sin(angle / 2.0);
  return vec4(axis.x * s, axis.y * s, axis.z * s, cos(angle / 2.0));
}

vec4 quat_rotation_to(vec3 from, vec3 to) {
	vec3 xunit = vec3(1.0, 0.0, 0.0);
	vec3 yunit = vec3(0.0, 1.0, 0.0);
	float dot = dot(from, to);
	if (dot < -0.999999) {
	    vec3 axis = cross(xunit, from);
	    if (length(axis) < 0.000001) {
	    	axis = cross(yunit, from);
	    }
	    axis = normalize(axis);
	    return quat(axis, PI);
	} else if (dot > 0.999999) {
		return vec4(0.0, 0.0, 0.0, 1.0);
	} else {
		vec3 axis = cross(from, to);
		return normalize(vec4(axis, 1.0 + dot));
	}
}

vec3 rotated(vec3 v, vec3 axis, float angle) {
  vec4 q = quat(axis, angle);
  vec3 t = cross(q.xyz, v) + q.w * v;
  return v + 2.0 * cross(q.xyz, t);
}

vec3 rotated(vec3 v, vec4 q) {
  vec3 t = cross(q.xyz, v) + q.w * v;
  return v + 2.0 * cross(q.xyz, t);
}

mat3 rotated(mat3 m, vec4 q) {
  return mat3(rotated(m[0], q), rotated(m[1], q), rotated(m[2], q));
}

float normalized_by_amount(uint n) {
	return float(n) / float(max(AMOUNT, 1u));
}
void update_orbital_velocity(inout Particle particle, mat4 emission_transform, mat4 transform) {
	if (abs(particle.orbital_speed) < 0.01 || particle.delta < 0.001) { return; }
	vec3 local_pos = (inverse(emission_transform) * transform[3]).xyz;
	vec3 next = rotated(local_pos, particle.orbital_axis, particle.orbital_speed * particle.delta);
	particle.position = (emission_transform * vec4(next, 0.0)).xyz;
	particle.orbital_velocity = (next - local_pos) / particle.delta;
}

void apply_radial_velocity(inout Particle particle) {
	vec3 d = particle.position;
	float mag = min(length(d), abs(particle.radial_velocity) * particle.delta);
	particle.position += normalize_or_zero(d) * mag * sign(particle.radial_velocity);
}

void m0_initialize_size(inout Particle particle) {
	vec3 s = vec3(0.050000, 0.050000, 0.050000);
	particle.initial_scale = s;
}

void m1_initialize_velocity(inout Particle particle) {
	vec3 v = vec3(0.000000, 0.000000, 0.001000);
	particle.initial_velocity = v;
}

uniform vec4 initial_color : source_color;

void m2_initialize_color(inout Particle particle) {
	vec4 c = initial_color;
	float a = 1.0;
	particle.initial_color = vec4(c.rgb, a);
}

void m3_align(inout Particle particle) {
	vec3 up = vec3(0.0, 1.0, 0.0);
	vec3 v = normalize(particle.velocity + particle.orbital_velocity + normalize(particle.position) * particle.radial_velocity);
	vec4 q = quat_rotation_to(up, v);
	mat3 m = mat3(1.0);
	particle.orientation = rotated(m, q);
}

void initialize(inout Particle particle) {
	particle.initial_position = vec3(0.0);
	particle.initial_color = vec4(1.0);
	particle.initial_scale = vec3(1.0);
	particle.initial_velocity = vec3(0.0);
	particle.initial_orbital_speed = 0.0;
	particle.spawn_direction = vec3(0.0);
	particle.animation_offset = 0.0;
	particle.animation_speed = 1.0;
	particle.rotation_axis = vec3(1.0, 0.0, 0.0);
	particle.initial_rotation = 0.0;
	particle.radial_velocity = 0.0;
	particle.orbital_axis = vec3(0.0, 1.0, 0.0);
	particle.orbital_velocity = vec3(0.0);
	m0_initialize_size(particle);
	m1_initialize_velocity(particle);
	m2_initialize_color(particle);
	particle.scale = particle.initial_scale;
	particle.color = particle.initial_color;
	particle.orbital_speed = particle.initial_orbital_speed;
}

void start() {
	Particle particle;
	// Use INDEX instead of NUMBER for repeatability.
	uint base_number = NUMBER;
	particle.seed = hash(base_number + uint(1) + RANDOM_SEED);
	particle.lifetime = LIFETIME;
	particle.index = INDEX;
	particle.number = NUMBER;
	particle.age = 0.0;
	particle.normalized_age = 0.0;
	particle.normalized_index = normalized_by_amount(INDEX);
	particle.normalized_number = normalized_by_amount(NUMBER);
	particle.position = vec3(0.0);
	initialize(particle);
	if (rand(particle.seed) > AMOUNT_RATIO) {
		ACTIVE = false;
	}
	if (RESTART_CUSTOM) {
		CUSTOM = vec4(0.0);
		CUSTOM.x = particle.initial_rotation;
	}
	if (RESTART_COLOR) {
		COLOR = particle.initial_color;
	}
	if (RESTART_ROT_SCALE) {
		TRANSFORM[0].xyz = rotated(vec3(1.0, 0.0, 0.0), particle.rotation_axis, particle.initial_rotation) * particle.initial_scale.x;
		TRANSFORM[1].xyz = rotated(vec3(0.0, 1.0, 0.0), particle.rotation_axis, particle.initial_rotation) * particle.initial_scale.y;
		TRANSFORM[2].xyz = rotated(vec3(0.0, 0.0, 1.0), particle.rotation_axis, particle.initial_rotation) * particle.initial_scale.z;
	}
	if (RESTART_POSITION) {
		TRANSFORM[3].xyz = particle.initial_position;
		TRANSFORM = EMISSION_TRANSFORM * TRANSFORM;
	}
	if (RESTART_VELOCITY) {
		VELOCITY = (EMISSION_TRANSFORM * vec4(particle.initial_velocity, 0.0)).xyz;
		VELOCITY += EMITTER_VELOCITY * 0.0;//inherit_emitter_velocity_ratio;
	}
}

void process() {
	Particle particle;
	// Use INDEX instead of NUMBER for repeatability.
	uint base_number = NUMBER;
	particle.seed = hash(base_number + uint(1) + RANDOM_SEED);
	particle.delta = DELTA;
	particle.lifetime = LIFETIME;
	particle.index = INDEX;
	particle.number = NUMBER;
	particle.age = 0.0;
	particle.normalized_age = 0.0;
	particle.normalized_index = normalized_by_amount(INDEX);
	particle.normalized_number = normalized_by_amount(NUMBER);
	particle.position = TRANSFORM[3].xyz;
	particle.velocity = VELOCITY;
	particle.orientation = mat3(
		normalize(TRANSFORM[0].xyz),
		normalize(TRANSFORM[1].xyz),
		normalize(TRANSFORM[2].xyz));
	particle.force = vec3(0.0);
	particle.emission_transform = EMISSION_TRANSFORM;
	particle.previous_transform = TRANSFORM;
	particle.rotation = CUSTOM.x;
	particle.just_spawned = CUSTOM.y == 0.0;
	particle.collided = COLLIDED;
	particle.collision_normal = COLLISION_NORMAL;
	particle.collision_depth = COLLISION_DEPTH;
	particle.color = COLOR;
	initialize(particle);
	CUSTOM.y += DELTA / particle.lifetime;
	CUSTOM.y = mix(CUSTOM.y, 1.0, INTERPOLATE_TO_END);
	CUSTOM.y = clamp(CUSTOM.y, 0.0, 1.0);
	particle.age = CUSTOM.y * particle.lifetime;
	particle.normalized_age = CUSTOM.y;
	m3_align(particle);
	if (abs(particle.orbital_speed) >= 0.01 && particle.delta >= 0.001) {
		vec3 local_pos = (inverse(particle.emission_transform) * vec4(particle.position, 1.0)).xyz;
		vec3 next = rotated(local_pos, particle.orbital_axis, particle.orbital_speed * particle.delta);
		particle.position = (particle.emission_transform * vec4(next, 0.0)).xyz;
		particle.orbital_velocity = (next - local_pos) / particle.delta;
	}
	if (abs(particle.radial_velocity) >= 0.01 && particle.delta >= 0.001) {
		vec3 local_pos = (inverse(particle.emission_transform) * vec4(particle.position, 1.0)).xyz;
		vec3 d = local_pos;
		float mag = min(length(d), abs(particle.radial_velocity) * particle.delta);
		vec3 next = local_pos + normalize_or_zero(d) * mag * sign(particle.radial_velocity);
		particle.position = (particle.emission_transform * vec4(next, 0.0)).xyz;
	}
	particle.position += particle.velocity * particle.delta;
	VELOCITY = particle.velocity;
	TRANSFORM[0].xyz = particle.orientation[0] * particle.scale.x;
	TRANSFORM[1].xyz = particle.orientation[1] * particle.scale.y;
	TRANSFORM[2].xyz = particle.orientation[2] * particle.scale.z;
	TRANSFORM[3].xyz = particle.position;
	COLOR = particle.color;
	CUSTOM.x = particle.rotation;
	
	if (particle.age >= LIFETIME) { ACTIVE = false;  }
}

"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_jlu4h"]
