[sub_resource type="Shader" id="Shader_1rx6d"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled;

uniform float emission = 1.0;

uniform sampler2D tex_1 : source_color, filter_linear_mipmap, repeat_enable;
uniform sampler2D noise_tex : source_color, filter_linear_mipmap, repeat_enable;
uniform vec2 noise_tiling = vec2(1.0);
uniform sampler2D gradient : source_color, repeat_disable;
uniform vec2 speed = vec2(0.0);
uniform float width : hint_range(0.0, 1.0, 0.01) = 1.0;
uniform float distortion_intensity = 1.0;

void vertex()
{
}

void fragment()
{
	float a = 1.0 - COLOR.b;
	vec4 noise = texture(noise_tex, UV * noise_tiling + speed * TIME);
	float d = distortion_intensity * ((1.0 - a) + smoothstep(0.0, 1.0, 1.0 - a) * 1.0);
	vec4 tex_sampled_1 = texture(tex_1, UV + (noise.r * 2.0 - 1.0) * d * 0.0);
	//float i = UV.x;
	//float mask = step((1.0 - width) * 0.5, i) * step(i, 0.5 + width * 0.5);
	ALPHA = clamp(tex_sampled_1.r * a, 0.0, 1.0);
	ALBEDO = texture(gradient, vec2(ALPHA)).rgb * emission;
}"

