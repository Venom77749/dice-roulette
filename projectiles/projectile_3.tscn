[sub_resource type="Shader" id="Shader_oei4o"]
code = "shader_type spatial;
render_mode unshaded, blend_add, cull_disabled;

uniform float opacity = 1.0;
uniform float emission = 1.0;

uniform sampler2D tex_1 : source_color, filter_linear_mipmap, repeat_disable;

float rand(inout uint seed) {
	int k;
	int s = int(seed);
	if (s == 0) {
		s = 305420679;
	}
	k = s / 127773;
	s = 16807 * (s - k * 127773) - 2836 * k;
	if (s < 0) {
		s += 2147483647;
	}
	seed = uint(s);
	return float(seed % uint(65536)) / 65535.0;
}

float rand_range(inout uint seed, float l, float h) {
	return l + (h - l) * rand(seed);
}

varying flat uint instance_id;
varying float age;

void vertex()
{
	instance_id = uint(INSTANCE_ID);
	age = INSTANCE_CUSTOM.y;
	vec3 dir = normalize(CAMERA_POSITION_WORLD - MODEL_MATRIX[3].xyz);
	vec3 pos = MODEL_MATRIX[3].xyz + dir * 1.0;
	mat4 model = mat4(
		normalize(MAIN_CAM_INV_VIEW_MATRIX[0]),
		normalize(MAIN_CAM_INV_VIEW_MATRIX[1]),
		normalize(MAIN_CAM_INV_VIEW_MATRIX[2]),
		vec4(pos, 1.0));
	model = model * mat4(
		vec4(cos(INSTANCE_CUSTOM.x), -sin(INSTANCE_CUSTOM.x), 0.0, 0.0),
		vec4(sin(INSTANCE_CUSTOM.x), cos(INSTANCE_CUSTOM.x), 0.0, 0.0),
		vec4(0.0, 0.0, 1.0, 0.0),
		vec4(0.0, 0.0, 0.0, 1.0));
	model = model * mat4(
		vec4(length(MODEL_MATRIX[0].xyz), 0.0, 0.0, 0.0),
		vec4(0.0, length(MODEL_MATRIX[1].xyz), 0.0, 0.0),
		vec4(0.0, 0.0, length(MODEL_MATRIX[2].xyz), 0.0),
		vec4(0.0, 0.0, 0.0, 1.0));
	MODELVIEW_MATRIX = VIEW_MATRIX * model;
	MODELVIEW_NORMAL_MATRIX = mat3(MODELVIEW_MATRIX);
}

void fragment()
{
	uint seed = instance_id;
	vec4 tex_sampled_1 = texture(tex_1, UV);
	ALPHA = COLOR.a;
	ALPHA = ALPHA * tex_sampled_1.r;
	ALPHA = clamp(ALPHA * opacity, 0.0, 1.0);
	ALBEDO = COLOR.rgb * emission;
	ALBEDO *= tex_sampled_1.rgb;
	
}


"

