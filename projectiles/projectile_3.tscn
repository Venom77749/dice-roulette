	x = (x >> uint(16)) ^ x;
	return x;
}

vec3 normalize_or_zero(vec3 v) {
  return length(v) > 0.0 ? normalize(v) : vec3(0.0, 0.0, 0.0);
}

vec3 normalize_or_up(vec3 v) {
  return length(v) > 0.0 ? normalize(v) : vec3(0.0, 1.0, 0.0);
}

vec4 quat(vec3 axis, float angle) {
  float s = sin(angle / 2.0);
  return vec4(axis.x * s, axis.y * s, axis.z * s, cos(angle / 2.0));
}

vec4 quat_rotation_to(vec3 from, vec3 to) {
	vec3 xunit = vec3(1.0, 0.0, 0.0);
	vec3 yunit = vec3(0.0, 1.0, 0.0);
	float dot = dot(from, to);
	if (dot < -0.999999) {
	    vec3 axis = cross(xunit, from);
	    if (length(axis) < 0.000001) {
	    	axis = cross(yunit, from);
	    }
	    axis = normalize(axis);
	    return quat(axis, PI);
	} else if (dot > 0.999999) {
		return vec4(0.0, 0.0, 0.0, 1.0);
	} else {
		vec3 axis = cross(from, to);
		return normalize(vec4(axis, 1.0 + dot));
	}
}

vec3 rotated(vec3 v, vec3 axis, float angle) {
  vec4 q = quat(axis, angle);
  vec3 t = cross(q.xyz, v) + q.w * v;
  return v + 2.0 * cross(q.xyz, t);
}

vec3 rotated(vec3 v, vec4 q) {
  vec3 t = cross(q.xyz, v) + q.w * v;
  return v + 2.0 * cross(q.xyz, t);
}

mat3 rotated(mat3 m, vec4 q) {
  return mat3(rotated(m[0], q), rotated(m[1], q), rotated(m[2], q));
}

float normalized_by_amount(uint n) {
	return float(n) / float(max(AMOUNT, 1u));
}
void update_orbital_velocity(inout Particle particle, mat4 emission_transform, mat4 transform) {
	if (abs(particle.orbital_speed) < 0.01 || particle.delta < 0.001) { return; }
	vec3 local_pos = (inverse(emission_transform) * transform[3]).xyz;
	vec3 next = rotated(local_pos, particle.orbital_axis, particle.orbital_speed * particle.delta);
	particle.position = (emission_transform * vec4(next, 0.0)).xyz;
	particle.orbital_velocity = (next - local_pos) / particle.delta;
}

void apply_radial_velocity(inout Particle particle) {
	vec3 d = particle.position;
	float mag = min(length(d), abs(particle.radial_velocity) * particle.delta);
	particle.position += normalize_or_zero(d) * mag * sign(particle.radial_velocity);
}

void m0_initialize_size(inout Particle particle) {
	vec3 s = vec3(0.300000, 0.600000, 0.300000);
	particle.initial_scale = s;
}

uniform vec4 u_m1_rgb : source_color;

void m1_initialize_color(inout Particle particle) {
	vec4 c = u_m1_rgb;
	float a = 0.2;
	particle.initial_color = vec4(c.rgb, a);
}

void m2_initialize_velocity(inout Particle particle) {
	vec3 v = vec3(0.000000, 0.000000, 0.001000);
	particle.initial_velocity = v;
}

void m3_initialize_position(inout Particle particle) {
	vec3 pos = vec3(0.000000, -0.010000, 0.000000);
	particle.initial_position = pos;
}

void m4_align(inout Particle particle) {
	vec3 up = vec3(0.0, 1.0, 0.0);
	vec3 v = normalize(particle.velocity + particle.orbital_velocity + normalize(particle.position) * particle.radial_velocity);
	vec4 q = quat_rotation_to(up, v);
	mat3 m = mat3(1.0);
	particle.orientation = rotated(m, q);
}

void initialize(inout Particle particle) {
	particle.initial_position = vec3(0.0);
	particle.initial_color = vec4(1.0);
	particle.initial_scale = vec3(1.0);
	particle.initial_velocity = vec3(0.0);
	particle.initial_orbital_speed = 0.0;
	particle.spawn_direction = vec3(0.0);
	particle.animation_offset = 0.0;
	particle.animation_speed = 1.0;
	particle.rotation_axis = vec3(1.0, 0.0, 0.0);
	particle.initial_rotation = 0.0;
	particle.radial_velocity = 0.0;
	particle.orbital_axis = vec3(0.0, 1.0, 0.0);
	particle.orbital_velocity = vec3(0.0);
	m0_initialize_size(particle);
	m1_initialize_color(particle);
	m2_initialize_velocity(particle);
	m3_initialize_position(particle);
	particle.scale = particle.initial_scale;
	particle.color = particle.initial_color;
	particle.orbital_speed = particle.initial_orbital_speed;
}

void start() {
	Particle particle;
	// Use INDEX instead of NUMBER for repeatability.
	uint base_number = NUMBER;
	particle.seed = hash(base_number + uint(1) + RANDOM_SEED);
	particle.lifetime = LIFETIME;
	particle.index = INDEX;
	particle.number = NUMBER;
	particle.age = 0.0;
	particle.normalized_age = 0.0;
	particle.normalized_index = normalized_by_amount(INDEX);
	particle.normalized_number = normalized_by_amount(NUMBER);
	particle.position = vec3(0.0);
	initialize(particle);
	if (rand(particle.seed) > AMOUNT_RATIO) {
		ACTIVE = false;
	}
	if (RESTART_CUSTOM) {
		CUSTOM = vec4(0.0);
		CUSTOM.x = particle.initial_rotation;
	}
	if (RESTART_COLOR) {
		COLOR = particle.initial_color;
	}
	if (RESTART_ROT_SCALE) {
		TRANSFORM[0].xyz = rotated(vec3(1.0, 0.0, 0.0), particle.rotation_axis, particle.initial_rotation) * particle.initial_scale.x;
		TRANSFORM[1].xyz = rotated(vec3(0.0, 1.0, 0.0), particle.rotation_axis, particle.initial_rotation) * particle.initial_scale.y;
		TRANSFORM[2].xyz = rotated(vec3(0.0, 0.0, 1.0), particle.rotation_axis, particle.initial_rotation) * particle.initial_scale.z;
	}
	if (RESTART_POSITION) {
		TRANSFORM[3].xyz = particle.initial_position;
		TRANSFORM = EMISSION_TRANSFORM * TRANSFORM;
	}
	if (RESTART_VELOCITY) {
		VELOCITY = (EMISSION_TRANSFORM * vec4(particle.initial_velocity, 0.0)).xyz;
		VELOCITY += EMITTER_VELOCITY * 0.0;//inherit_emitter_velocity_ratio;
	}
}

void process() {
	Particle particle;
	// Use INDEX instead of NUMBER for repeatability.
	uint base_number = NUMBER;
	particle.seed = hash(base_number + uint(1) + RANDOM_SEED);
	particle.delta = DELTA;
	particle.lifetime = LIFETIME;
	particle.index = INDEX;
	particle.number = NUMBER;
	particle.age = 0.0;
	particle.normalized_age = 0.0;
	particle.normalized_index = normalized_by_amount(INDEX);
	particle.normalized_number = normalized_by_amount(NUMBER);
	particle.position = TRANSFORM[3].xyz;
	particle.velocity = VELOCITY;
	particle.orientation = mat3(
		normalize(TRANSFORM[0].xyz),
		normalize(TRANSFORM[1].xyz),
		normalize(TRANSFORM[2].xyz));
	particle.force = vec3(0.0);
	particle.emission_transform = EMISSION_TRANSFORM;
	particle.previous_transform = TRANSFORM;
	particle.rotation = CUSTOM.x;
	particle.just_spawned = CUSTOM.y == 0.0;
	particle.collided = COLLIDED;
	particle.collision_normal = COLLISION_NORMAL;
	particle.collision_depth = COLLISION_DEPTH;
	particle.color = COLOR;
	initialize(particle);
	CUSTOM.y += DELTA / particle.lifetime;
	CUSTOM.y = mix(CUSTOM.y, 1.0, INTERPOLATE_TO_END);
	CUSTOM.y = clamp(CUSTOM.y, 0.0, 1.0);
	particle.age = CUSTOM.y * particle.lifetime;
	particle.normalized_age = CUSTOM.y;
	m4_align(particle);
	if (abs(particle.orbital_speed) >= 0.01 && particle.delta >= 0.001) {
		vec3 local_pos = (inverse(particle.emission_transform) * vec4(particle.position, 1.0)).xyz;
		vec3 next = rotated(local_pos, particle.orbital_axis, particle.orbital_speed * particle.delta);
		particle.position = (particle.emission_transform * vec4(next, 0.0)).xyz;
		particle.orbital_velocity = (next - local_pos) / particle.delta;
	}
	if (abs(particle.radial_velocity) >= 0.01 && particle.delta >= 0.001) {
		vec3 local_pos = (inverse(particle.emission_transform) * vec4(particle.position, 1.0)).xyz;
		vec3 d = local_pos;
		float mag = min(length(d), abs(particle.radial_velocity) * particle.delta);
		vec3 next = local_pos + normalize_or_zero(d) * mag * sign(particle.radial_velocity);
		particle.position = (particle.emission_transform * vec4(next, 0.0)).xyz;
	}
	particle.position += particle.velocity * particle.delta;
	VELOCITY = particle.velocity;
	TRANSFORM[0].xyz = particle.orientation[0] * particle.scale.x;
	TRANSFORM[1].xyz = particle.orientation[1] * particle.scale.y;
	TRANSFORM[2].xyz = particle.orientation[2] * particle.scale.z;
	TRANSFORM[3].xyz = particle.position;
	COLOR = particle.color;
	CUSTOM.x = particle.rotation;
	
	if (particle.age >= LIFETIME) { ACTIVE = false;  }
}

