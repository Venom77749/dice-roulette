[sub_resource type="Shader" id="Shader_g7oo0"]
code = "shader_type spatial;
render_mode unshaded, blend_add, cull_disabled;

uniform float opacity = 1.0;
uniform float emission = 1.0;

uniform sampler2D main_tex : source_color, filter_linear_mipmap, repeat_disable;

uniform uint horizontal_frames = 1;
uniform uint vertical_frames = 1;

float rand(inout uint seed) {
	int k;
	int s = int(seed);
	if (s == 0) {
		s = 305420679;
	}
	k = s / 127773;
	s = 16807 * (s - k * 127773) - 2836 * k;
	if (s < 0) {
		s += 2147483647;
	}
	seed = uint(s);
	return float(seed % uint(65536)) / 65535.0;
}

float rand_range(inout uint seed, float l, float h) {
	return l + (h - l) * rand(seed);
}

varying flat uint instance_id;
varying float age;
varying vec2 uv_animated;

void vertex()
{
	instance_id = uint(INSTANCE_ID);
	age = INSTANCE_CUSTOM.y;
	vec3 up = normalize(MODEL_MATRIX[1].xyz);
	vec3 right = normalize(cross(up, MAIN_CAM_INV_VIEW_MATRIX[2].xyz));
	vec3 front = normalize(cross(right, up));
	MODELVIEW_MATRIX = VIEW_MATRIX * mat4(
		vec4(right, 0.0),
		vec4(up, 0.0),
		vec4(front, 0.0),
		MODEL_MATRIX[3]);
	MODELVIEW_MATRIX = MODELVIEW_MATRIX * mat4(
			vec4(length(MODEL_MATRIX[0].xyz), 0.0, 0.0, 0.0),
			vec4(0.0, length(MODEL_MATRIX[1].xyz), 0.0, 0.0),
			vec4(0.0, 0.0, length(MODEL_MATRIX[2].xyz), 0.0),
			vec4(0.0, 0.0, 0.0, 1.0));
	MODELVIEW_NORMAL_MATRIX = mat3(MODELVIEW_MATRIX);
	{
		uint h = max(horizontal_frames, 1u);
		uint v = max(vertical_frames, 1u);
		uint num = h * v;
		uint idx = min(uint(float(num) * INSTANCE_CUSTOM.z) % num, num - 1u);
		uint iy = idx / h;
		uint ix = idx - iy * h;
		float w = 1.0 / float(h);
		float height = 1.0 / float(v);
		uv_animated.x = float(ix) * w + UV.x * w;
		uv_animated.y = float(iy) * height + UV.y * height;
	}
}

float remap(float value, float input_min, float input_max, float output_min, float output_max) {
	return (value - input_min) / (input_max - input_min) * (output_max - output_min) + output_min;
}

void fragment()
{
	uint seed = instance_id;
	vec4 main_s = texture(main_tex, uv_animated);
	float feather = 0.05;
	float age_ = remap(age, 0.0, 1.0, -feather, 1.0);
	float erosion = smoothstep(age_, age_ + feather, main_s.r);
	ALPHA = COLOR.a * erosion;
	ALPHA *= smoothstep(0.05, 0.06, main_s.r);
	ALPHA = clamp(ALPHA * opacity, 0.0, 1.0);
	ALBEDO = COLOR.rgb * emission;
	ALBEDO *= main_s.rgb;
	
}


"

