[sub_resource type="Shader" id="Shader_f01yn"]
code = "shader_type spatial;
render_mode unshaded;

uniform float opacity = 1.0;
uniform float emission = 1.0;

uniform sampler2D dissolve_tex : source_color, filter_linear_mipmap, repeat_enable;
uniform vec2 dissolve_tiling = vec2(1.0);
uniform vec2 dissolve_offset = vec2(0.0);
uniform vec2 dissolve_speed = vec2(0.0);

float rand(inout uint seed) {
	int k;
	int s = int(seed);
	if (s == 0) {
		s = 305420679;
	}
	k = s / 127773;
	s = 16807 * (s - k * 127773) - 2836 * k;
	if (s < 0) {
		s += 2147483647;
	}
	seed = uint(s);
	return float(seed % uint(65536)) / 65535.0;
}

float rand_range(inout uint seed, float l, float h) {
	return l + (h - l) * rand(seed);
}

varying flat uint instance_id;
varying float age;

void vertex()
{
	instance_id = uint(INSTANCE_ID);
	age = INSTANCE_CUSTOM.y;
}

float remap(float value, float input_min, float input_max, float output_min, float output_max) {
	return (clamp(value, input_min, input_max) - input_min) / (input_max - input_min) * (output_max - output_min) + output_min;
}

uniform sampler2D dissolve_curve : repeat_disable;

void fragment()
{
	uint seed = instance_id;
	vec4 dissolve_s = texture(dissolve_tex, UV * dissolve_tiling + dissolve_offset + vec2(rand_range(seed, 0.0, 1.0), rand_range(seed, 0.0, 1.0)) + dissolve_speed * TIME);
	float d = texture(dissolve_curve, vec2(age)).r;
	float feather = 0.01;
	float t = remap(d, 0.0, 1.0, -feather, 1.0);
	float dissolve = smoothstep(t, t + feather, dissolve_s.r);
	ALPHA = COLOR.a * dissolve;
	ALPHA = clamp(ALPHA * opacity, 0.0, 1.0);
	ALBEDO = COLOR.rgb * emission;
}


"

