[sub_resource type="Shader" id="Shader_1rx6d"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled;

uniform float emission = 1.0;

uniform sampler2D tex_1 : source_color, filter_linear_mipmap, repeat_enable;
uniform vec2 offset = vec2(0.0);
uniform sampler2D gradient : source_color, repeat_disable;

void vertex()
{
}

void fragment()
{
	float a = 1.0 - COLOR.b;
	vec4 tex_sampled_1 = texture(tex_1, UV + offset);
	ALPHA = clamp(tex_sampled_1.r * a, 0.0, 1.0);
	ALBEDO = texture(gradient, vec2(a)).rgb * emission * tex_sampled_1.rgb;
}"

