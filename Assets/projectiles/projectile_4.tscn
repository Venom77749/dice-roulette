[sub_resource type="GDScript" id="GDScript_p3veb"]
script/source = "@tool
extends Node3D

const TRAIL := preload(\"res://projectiles/scripts/trail3d.gd\")

@export var speed := 10.0
@export var fade_time := 0.3
@export_storage var lifetime := 1.0

var age := 0.0
var direction := Vector3(0, 0, 1)
var collided := false

var list := [
	[ \"Lifetime\", [
		{ \"property\": \"lifetime\" },
		{ \"node_path\": \"Emitters/Core\", \"property\": \"lifetime\" },
		{ \"node_path\": \"Emitters/CoreLong\", \"property\": \"lifetime\" },
		{ \"node_path\": \"Emitters/Glow\", \"property\": \"lifetime\" },
		{ \"node_path\": \"Emitters/GlowLong\", \"property\": \"lifetime\" },
	]],
	[ \"Main Color\", [
		{ \"node_path\": \"Emitters/Glow\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m1_rgb\" },
		{ \"node_path\": \"Emitters/GlowLong\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
		{ \"node_path\": \"Emitters/Sparks\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
		{ \"node_path\": \"Impact/Glow\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m0_rgb\" },
		{ \"node_path\": \"Impact/GlowHard\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m0_rgb\" },
		{ \"node_path\": \"Impact/Flare\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/u_m1_rgb\" },
		{ \"node_path\": \"Impact/Sparks\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
		{ \"node_path\": \"Impact/Lightning\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
	]],
	[ \"Projectile Color\", [
		{ \"node_path\": \"Emitters/Core\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
		{ \"node_path\": \"Emitters/CoreLong\", \"object_path\": \"process_material\", \"property\": \"shader_parameter/initial_color\" },
	]],
	[ \"Trail Color\", [
		{ \"node_path\": \"TrailPrefab\", \"object_path\": \"material_override\", \"property\": \"shader_parameter/gradient\" }
	]],
]

func _ready() -> void:
	if !Engine.is_editor_hint():
		for e in $Emitters.get_children():
			e.restart()

func _process(delta: float) -> void:
	if Engine.is_editor_hint():
		return
	age += delta
	if collided:
		var s: float = $TrailPrefab.scale.y
		if s > 0.01:
			$TrailPrefab.scale.y = min(s, max(0.001, $TrailPrefab.scale.y - delta * (1.0 / maxf(fade_time, 0.01))))
	else:
		var ft := minf(lifetime, fade_time)
		var fade_progress: float = age - (lifetime - ft)
		if fade_progress > 0:
			var t := clampf(fade_progress / ft, 0.0, 1.0)
			var s := maxf(1.0 - t, 0.001)
			get_node(\"Emitters\").scale = Vector3(s, s, s)
			get_node(\"TrailPrefab\").scale = Vector3(s, s, s)
			for e in get_node(\"Emitters\").get_children():
				e.emitting = false
	if age > lifetime + 0.5:
		queue_free()

func _physics_process(delta: float) -> void:
	if Engine.is_editor_hint():
		return
	var motion := direction * delta * speed
	if collided:
		$Emitters.position += Vector3(0, 0, 1) * delta * speed
		return
	position += motion
	if age > lifetime:
		return
	var collision: KinematicCollision3D = $CharacterBody3D.move_and_collide(motion)
	if collision:
		explode()

func launch(dir: Vector3) -> void:
	dir = dir.normalized()
	direction = dir
	$CharacterBody3D.position = global_position
	var right := Vector3(0, 1, 0).cross(dir).normalized()
	var up := dir.cross(right).normalized()
	basis = Basis(
		right * scale.x,
		up * scale.y,
		dir * scale.z
	)

func explode() -> void:
	collided = true
	for e in $Emitters.get_children():
		e.emitting = false
		e.visible = false
	for e in $Impact.get_children():
		e.restart()

func _get_property_list() -> Array[Dictionary]:
	if !is_inside_tree() or !Engine.is_editor_hint():
		return []
	var l: Array[Dictionary]
	for group in list:
		for prop in group[1]:
			var node: Node = self
			if prop.has(\"node_path\"):
				node = get_node(prop.node_path)
				if !node:
					print(\"Node not found %s\" % prop.node_path)
					continue
			var obj: Object = node
			if prop.has(\"object_path\"):
				obj = node.get(prop.object_path)
				if !obj:
					print(\"Object not found %s\" % prop.object_path)
					continue
				if prop.has(\"sub_object_path\"):
					obj = obj.get(prop.sub_object_path)
					if !obj:
						print(\"Sub-object not found %s\" % prop.sub_object_path)
						continue
			if obj == self:
				continue
			var prop_list = obj.get_property_list()
			var done := false
			for p in prop_list:
				if p.name == prop.property:
					var property = p.duplicate()
					property.name = group[0]
					l.push_back(property)
					done = true
					break
			if done:
				break
	return l

func _get(property: StringName) -> Variant:
	if !is_inside_tree() or !Engine.is_editor_hint():
		return null
	var r := find_property(property)
	if !r.is_empty():
		return r.object.get(r.property)
	else:
		return null

func _set(property: StringName, value: Variant) -> bool:
	if !is_inside_tree() or !Engine.is_editor_hint():
		return false
	for group in list:
		if group[0] != property:
			continue
		for prop in group[1]:
			var node: Node = self
			if prop.has(\"node_path\"):
				node = get_node(prop.node_path)
				if !node:
					continue
			var obj: Object = node
			if prop.has(\"object_path\"):
				obj = node.get(prop.object_path)
				if !obj:
					continue
				if prop.has(\"sub_object_path\"):
					obj = obj.get(prop.sub_object_path)
					if !obj:
						continue
			obj.set(prop.property, value)
	return false

func find_property(property: StringName) -> Dictionary:
	for group in list:
		if property != group[0]:
			continue
		for prop in group[1]:
			var node: Node = self
			if prop.has(\"node_path\"):
				node = get_node(prop.node_path)
				if !node:
					continue
			var obj: Object = node
			if prop.has(\"object_path\"):
				obj = node.get(prop.object_path)
				if !obj:
					continue
				if prop.has(\"sub_object_path\"):
					obj = obj.get(prop.sub_object_path)
					if !obj:
						continue
			return { \"node\": node, \"object\": obj, \"property\": prop.property }
	return {}
"

[sub_resource type="Shader" id="Shader_shl4u"]
code = "shader_type spatial;
render_mode unshaded, blend_add;

uniform float emission = 1.0;
uniform sampler2D main_tex : source_color, filter_linear_mipmap, repeat_disable;
uniform sampler2D gradient : source_color, repeat_enable;
uniform float speed = 1.0;

void vertex()
{
}

float fresnel(float power, vec3 normal, vec3 view)
{
	return pow((1.0 - clamp(dot(normalize(normal), normalize(view)), 0.0, 1.0 )), power);
}

void fragment()
{
	float mask = texture(main_tex, UV).r;
	ALPHA = clamp(smoothstep(0.2, 1.0, 1.0 - fresnel(0.5, NORMAL, VIEW)), 0.0, 1.0) * mask * COLOR.a;
	ALBEDO = COLOR.rgb * emission * texture(gradient, vec2(TIME * speed)).rgb;
}"

[sub_resource type="Gradient" id="Gradient_shl4u"]
offsets = PackedFloat32Array(0, 0.51666665, 1)
colors = PackedColorArray(1, 1, 1, 1, 0.67, 0.67, 0.67, 1, 1, 1, 1, 1)

