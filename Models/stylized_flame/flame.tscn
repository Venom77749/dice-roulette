[sub_resource type="Shader" id="Shader_j17v3"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled;

uniform float opacity = 1.0;
uniform float emission = 1.0;
uniform vec3 color : source_color;

uniform sampler2D main_tex : source_color, filter_linear_mipmap, repeat_disable;

uniform sampler2D distortion_tex : source_color, filter_linear_mipmap, repeat_enable;
uniform vec2 distortion_tiling = vec2(1.0);
uniform vec2 distortion_offset = vec2(0.0);
uniform vec2 distortion_speed = vec2(0.0);

uniform sampler2D distortion_mask_tex : source_color, filter_linear_mipmap, repeat_disable;

uniform vec2 distortion_power = vec2(0.0);

uniform sampler2D dissolve_tex : source_color, filter_linear_mipmap, repeat_enable;
uniform vec2 dissolve_tiling = vec2(1.0);
uniform float dissolve_feather = 0.025;
uniform sampler2D dissolve_curve_tex : filter_linear, repeat_disable;

float remap(float value, float input_min, float input_max, float output_min, float output_max) {
	return (clamp(value, input_min, input_max) - input_min) / (input_max - input_min) * (output_max - output_min) + output_min;
}

varying flat uint instance_id;
varying float age;

void vertex()
{
	instance_id = uint(INSTANCE_ID);
	age = INSTANCE_CUSTOM.y;
	vec3 up = normalize(MODEL_MATRIX[1].xyz);
	vec3 right = normalize(cross(up, MAIN_CAM_INV_VIEW_MATRIX[2].xyz));
	vec3 front = normalize(cross(right, up));
	MODELVIEW_MATRIX = VIEW_MATRIX * mat4(
		vec4(right, 0.0),
		vec4(up, 0.0),
		vec4(front, 0.0),
		MODEL_MATRIX[3]);
	MODELVIEW_MATRIX = MODELVIEW_MATRIX * mat4(
			vec4(length(MODEL_MATRIX[0].xyz), 0.0, 0.0, 0.0),
			vec4(0.0, length(MODEL_MATRIX[1].xyz), 0.0, 0.0),
			vec4(0.0, 0.0, length(MODEL_MATRIX[2].xyz), 0.0),
			vec4(0.0, 0.0, 0.0, 1.0));
	MODELVIEW_NORMAL_MATRIX = mat3(MODELVIEW_MATRIX);
}

void fragment()
{
	float distortion_s = texture(distortion_tex, UV * distortion_tiling + distortion_offset + distortion_speed * TIME).r;
	float mask = texture(distortion_mask_tex, UV).r;
	distortion_s *= 1.0 - mask;
	vec2 distortion = distortion_power * distortion_s;
	vec4 main_s = texture(main_tex, UV + distortion);
	float dissolve_s = texture(dissolve_tex, UV * dissolve_tiling + distortion * dissolve_tiling + distortion_speed * TIME * 0.5).r;
	float dissolve_t = texture(dissolve_curve_tex, vec2(age)).r;
	dissolve_t = remap(dissolve_t, 0.0, 1.0, -dissolve_feather, 1.0);
	ALPHA = COLOR.a;
	ALPHA *= main_s.r;
	ALPHA = clamp(ALPHA * opacity, 0.0, 1.0);
	ALPHA = smoothstep(0.0, 0.025, ALPHA);
	float dissolve = clamp(remap(1.0 - mask, 0.9, 1.0, 1.0, 0.0) + dissolve_s, 0.0, 1.0);
	ALPHA *= smoothstep(dissolve_t, dissolve_t + dissolve_feather, dissolve);
	ALBEDO = COLOR.rgb * emission * color;
}
"

